{
    "name": "microloan",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "test": "pnpm run lint && pnpm run typecheck && pnpm --filter db run prisma:validate",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "db:push": "node ./scripts/guarded-db-push.mjs",
        "db:migrate:deploy": "pnpm --filter db migrate:deploy",
        "db:seed": "pnpm --filter db db:seed",
        "start": "pnpm run db:migrate:deploy && eval \"${START_COMMAND:-node apps/api/dist/main}\"",
        "security:scan-hardcodes": "node ./scripts/security-scan.mjs hardcodes",
        "security:scan-timebombs": "node ./scripts/security-scan.mjs timebombs",
        "security:scan-memory-stores": "node ./scripts/security-scan.mjs memory",
        "security:prod-config-check": "node ./scripts/prod-config-check.mjs",
        "security:ci": "pnpm run security:scan-hardcodes && pnpm run security:scan-timebombs && pnpm run security:scan-memory-stores && pnpm run security:prod-config-check"
    },
    "devDependencies": {
        "prettier": "^3.2.5",
        "tsx": "^4.21.0",
        "turbo": "^1.13.0",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "packageManager": "pnpm@9.0.0"
}
