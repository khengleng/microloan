generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  borrowers  Borrower[]
  loans      Loan[]
  repayments Repayment[]
  auditLogs  AuditLog[]
}

enum Role {
  ADMIN
  OPS
  AUDITOR
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  email        String   @unique
  passwordHash String
  role         Role     @default(OPS)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]
}

model Borrower {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  firstName String
  lastName  String
  phone     String?
  address   String?
  idNumber  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans Loan[]
}

enum LoanStatus {
  DRAFT
  DISBURSED
  CLOSED
  DEFAULTED
}

enum InterestMethod {
  FLAT
  REDUCING_BALANCE
}

model Loan {
  id                 String         @id @default(uuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id])
  borrowerId         String
  borrower           Borrower       @relation(fields: [borrowerId], references: [id])
  status             LoanStatus     @default(DRAFT)
  principal          Decimal        @db.Decimal(10, 2)
  annualInterestRate Decimal        @db.Decimal(5, 2)
  termMonths         Int
  interestMethod     InterestMethod
  startDate          DateTime
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  schedules  RepaymentSchedule[]
  repayments Repayment[]

  @@index([tenantId])
}

model RepaymentSchedule {
  id                   String   @id @default(uuid())
  loanId               String
  loan                 Loan     @relation(fields: [loanId], references: [id])
  installmentNumber    Int
  dueDate              DateTime
  principalAmount      Decimal  @db.Decimal(10, 2)
  interestAmount       Decimal  @db.Decimal(10, 2)
  totalAmount          Decimal  @db.Decimal(10, 2)
  outstandingPrincipal Decimal  @db.Decimal(10, 2)
  paidPrincipal        Decimal  @default(0) @db.Decimal(10, 2)
  paidInterest         Decimal  @default(0) @db.Decimal(10, 2)
  isPaid               Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Repayment {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  loanId        String
  loan          Loan     @relation(fields: [loanId], references: [id])
  amount        Decimal  @db.Decimal(10, 2)
  principalPaid Decimal  @default(0) @db.Decimal(10, 2)
  interestPaid  Decimal  @default(0) @db.Decimal(10, 2)
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // CREATE, UPDATE, DELETE
  entity    String // Borrower, Loan, Repayment
  entityId  String
  metadata  Json? // Stores old/new values
  createdAt DateTime @default(now())
}
