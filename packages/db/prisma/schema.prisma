generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  telegramBotToken String?  @unique // Per-tenant bot token
  plan                 String   @default("FREE") // Basic subscription visibility
  status               String   @default("ACTIVE") // ACTIVE, SUSPENDED
  stripeCustomerId     String?
  stripeSubscriptionId String?
  // Fix 5: configurable late penalty in $USD per overdue installment per day
  penaltyRatePerDay    Decimal  @default(10.00) @db.Decimal(8, 2)
  // Fix 9: GDPR soft-delete — set when erasure is requested, hard-delete job runs after 30 days
  deletedAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users        User[]
  borrowers    Borrower[]
  loans        Loan[]
  repayments   Repayment[]
  auditLogs    AuditLog[]
  documents    Document[]
  loanProducts LoanProduct[]
}

enum Role {
  SUPERADMIN
  ADMIN
  OPERATOR
  FINANCE
  SALES
  CX
}

model User {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  email            String    @unique
  passwordHash     String
  twoFactorSecret  String?   // For MFA
  twoFactorEnabled Boolean   @default(false)
  isActive         Boolean   @default(true) // For soft delete / suspension
  role             Role      @default(OPERATOR)
  telegramChatId   String?   // Staff's telegram chat ID
  loginAttempts    Int       @default(0)  // Brute-force counter
  lockedUntil      DateTime? // Account locked until this timestamp
  lastLoginAt      DateTime? // Last successful login
  lastLoginIp      String?   // Last known IP for anomaly detection
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  auditLogs AuditLog[]
  @@index([tenantId])
  @@index([email])
}

model Borrower {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  firstName      String
  lastName       String
  phone          String?
  address        String?
  idNumber       String?  @unique
  telegramChatId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  loans Loan[]
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
  CLOSED
  DEFAULTED
}

enum InterestMethod {
  FLAT
  REDUCING_BALANCE
}

model LoanProduct {
  id               String           @id @default(uuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  name             String           // e.g., "Daily Loan", "Weekly Loan", "Mortgage Loan"
  description      String?
  interestMethod   InterestMethod
  isActive         Boolean          @default(true)
  // Fix 5: per-product penalty override (null = use tenant default)
  penaltyRatePerDay Decimal?        @db.Decimal(8, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  policies         LoanPolicy[]
  loans            Loan[]
}

model LoanPolicy {
  id             String       @id @default(uuid())
  productId      String
  product        LoanProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  creditRating   String       // e.g., "A", "B", "C", "EXCELLENT", "GOOD", "FAIR"
  interestRate   Decimal      @db.Decimal(5, 2)
  minTermMonths  Int?
  maxTermMonths  Int?
  minPrincipal   Decimal?     @db.Decimal(10, 2)
  maxPrincipal   Decimal?     @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Loan {
  id                 String         @id @default(uuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id])
  borrowerId         String
  borrower           Borrower       @relation(fields: [borrowerId], references: [id])
  productId          String?
  product            LoanProduct?   @relation(fields: [productId], references: [id])
  creditRatingApplied String?
  status             LoanStatus     @default(PENDING)
  principal          Decimal        @db.Decimal(10, 2)
  annualInterestRate Decimal        @db.Decimal(5, 2)
  termMonths         Int
  interestMethod     InterestMethod
  startDate          DateTime
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  schedules    RepaymentSchedule[]
  repayments   Repayment[]
  documents    Document[]
  collaterals  Collateral[]
  guarantors   Guarantor[]
  interactions LoanInteraction[]

  // Approval Workflow Fields
  approvedBy   String?
  approvedAt   DateTime?
  rejectedBy   String?
  rejectedAt   DateTime?
  rejectionReason String?

  @@index([tenantId])
}

model Collateral {
  id          String   @id @default(uuid())
  loanId      String
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  type        String   // e.g., "LAND_TITLE", "VEHICLE", "GOLD", "OTHER"
  description String
  value       Decimal  @db.Decimal(10, 2)
  idNumber    String?  // e.g., Land title number or license plate
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Guarantor {
  id        String   @id @default(uuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  idNumber  String?
  relation  String?  // e.g., "SPOUSE", "PARENT", "COLLEAGUE"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoanInteraction {
  id        String   @id @default(uuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  userId    String
  title     String?  // e.g., "Follow-up Call", "Home Visit"
  notes     String
  type      String   @default("NOTE") // NOTE, CALL, VISIT, SYSTEM
  createdAt DateTime @default(now())
}

model RepaymentSchedule {
  id                   String   @id @default(uuid())
  loanId               String
  loan                 Loan     @relation(fields: [loanId], references: [id])
  installmentNumber    Int
  dueDate              DateTime
  principalAmount      Decimal  @db.Decimal(10, 2)
  interestAmount       Decimal  @db.Decimal(10, 2)
  penaltyAmount        Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount          Decimal  @db.Decimal(10, 2)
  outstandingPrincipal Decimal  @db.Decimal(10, 2)
  paidPrincipal        Decimal  @default(0) @db.Decimal(10, 2)
  paidInterest         Decimal  @default(0) @db.Decimal(10, 2)
  paidPenalty          Decimal  @default(0) @db.Decimal(10, 2)
  isPaid               Boolean  @default(false)
  penaltyLastAppliedAt DateTime? // Guard: ensures penalty is applied at most once per day
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Repayment {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  loanId        String
  loan          Loan     @relation(fields: [loanId], references: [id])
  amount        Decimal  @db.Decimal(10, 2)
  principalPaid Decimal  @default(0) @db.Decimal(10, 2)
  interestPaid  Decimal  @default(0) @db.Decimal(10, 2)
  penaltyPaid   Decimal  @default(0) @db.Decimal(10, 2)
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?  // Nullable  — allows anonymous security events (e.g. unknown email login)
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // CREATE, UPDATE, DELETE, LOGIN
  entity    String   // Borrower, Loan, Repayment, User, Tenant
  entityId  String
  metadata  Json?    // Masked metadata only — never raw PII
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([userId])
}

model Document {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id])
  name      String
  content   String   @db.Text // Base64 content or public URL
  type      String // e.g., "application/pdf", "image/png", or "url"
  createdAt DateTime @default(now())
}
