generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  telegramBotToken String?  @unique // Per-tenant bot token
  plan             String   @default("FREE") // Basic subscription visibility
  status           String   @default("ACTIVE") // ACTIVE, SUSPENDED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users        User[]
  borrowers    Borrower[]
  loans        Loan[]
  repayments   Repayment[]
  auditLogs    AuditLog[]
  documents    Document[]
  loanProducts LoanProduct[]
}

enum Role {
  SUPERADMIN
  ADMIN
  OPERATOR
  FINANCE
  SALES
  CX
}

model User {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  email            String   @unique
  passwordHash     String
  twoFactorSecret  String? // For MFA
  twoFactorEnabled Boolean  @default(false)
  role             Role     @default(OPERATOR)
  telegramChatId   String? // Staff's telegram chat ID
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  auditLogs AuditLog[]
}

model Borrower {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  firstName      String
  lastName       String
  phone          String?
  address        String?
  idNumber       String?  @unique
  telegramChatId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  loans Loan[]
}

enum LoanStatus {
  DRAFT
  APPROVED
  DISBURSED
  CLOSED
  DEFAULTED
}

enum InterestMethod {
  FLAT
  REDUCING_BALANCE
}

model LoanProduct {
  id             String           @id @default(uuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  name           String           // e.g., "Daily Loan", "Weekly Loan", "Mortgage Loan"
  description    String?
  interestMethod InterestMethod
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  policies       LoanPolicy[]
  loans          Loan[]
}

model LoanPolicy {
  id             String       @id @default(uuid())
  productId      String
  product        LoanProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  creditRating   String       // e.g., "A", "B", "C", "EXCELLENT", "GOOD", "FAIR"
  interestRate   Decimal      @db.Decimal(5, 2)
  minTermMonths  Int?
  maxTermMonths  Int?
  minPrincipal   Decimal?     @db.Decimal(10, 2)
  maxPrincipal   Decimal?     @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Loan {
  id                 String         @id @default(uuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id])
  borrowerId         String
  borrower           Borrower       @relation(fields: [borrowerId], references: [id])
  productId          String?
  product            LoanProduct?   @relation(fields: [productId], references: [id])
  creditRatingApplied String?
  status             LoanStatus     @default(DRAFT)
  principal          Decimal        @db.Decimal(10, 2)
  annualInterestRate Decimal        @db.Decimal(5, 2)
  termMonths         Int
  interestMethod     InterestMethod
  startDate          DateTime
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  schedules  RepaymentSchedule[]
  repayments Repayment[]
  documents  Document[]

  @@index([tenantId])
}

model RepaymentSchedule {
  id                   String   @id @default(uuid())
  loanId               String
  loan                 Loan     @relation(fields: [loanId], references: [id])
  installmentNumber    Int
  dueDate              DateTime
  principalAmount      Decimal  @db.Decimal(10, 2)
  interestAmount       Decimal  @db.Decimal(10, 2)
  totalAmount          Decimal  @db.Decimal(10, 2)
  outstandingPrincipal Decimal  @db.Decimal(10, 2)
  paidPrincipal        Decimal  @default(0) @db.Decimal(10, 2)
  paidInterest         Decimal  @default(0) @db.Decimal(10, 2)
  isPaid               Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Repayment {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  loanId        String
  loan          Loan     @relation(fields: [loanId], references: [id])
  amount        Decimal  @db.Decimal(10, 2)
  principalPaid Decimal  @default(0) @db.Decimal(10, 2)
  interestPaid  Decimal  @default(0) @db.Decimal(10, 2)
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // CREATE, UPDATE, DELETE
  entity    String // Borrower, Loan, Repayment
  entityId  String
  metadata  Json? // Stores old/new values
  createdAt DateTime @default(now())
}

model Document {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id])
  name      String
  content   String   @db.Text // Base64 content or public URL
  type      String // e.g., "application/pdf", "image/png", or "url"
  createdAt DateTime @default(now())
}
